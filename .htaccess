# AINTERCOM - Configuration Apache .htaccess
# Redirections et optimisations pour aintercom.fr

# Activer le moteur de réécriture
RewriteEngine On

# ──────────────────────────────────────────────────────────────
# REDIRECTION INDEX.HTML → RACINE
# ──────────────────────────────────────────────────────────────
# Redirige /index.html vers / (racine) avec code 301 permanent
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^(.*)index\.html$ /$1 [R=301,L]

# ──────────────────────────────────────────────────────────────
# REDIRECTIONS POUR URLS PROPRES
# ──────────────────────────────────────────────────────────────
# Redirige /legal.html vers / (301 permanent) - maintenant intégré dans index.html
RewriteCond %{THE_REQUEST} /legal\.html [NC]
RewriteRule ^legal\.html$ / [R=301,L]

# Redirige /cgv.html vers / (301 permanent) - maintenant intégré dans index.html
RewriteCond %{THE_REQUEST} /cgv\.html [NC]
RewriteRule ^cgv\.html$ / [R=301,L]

# Redirige /mentionslegales vers / (301 permanent) - maintenant intégré dans index.html
RewriteCond %{THE_REQUEST} /mentionslegales [NC]
RewriteRule ^mentionslegales$ / [R=301,L]

# Redirige /cgl vers / (301 permanent) - maintenant intégré dans index.html
RewriteCond %{THE_REQUEST} /cgl [NC]
RewriteRule ^cgl$ / [R=301,L]

# Redirige /mentionslegales.html vers / (301 permanent) - fichier supprimé
RewriteCond %{THE_REQUEST} /mentionslegales\.html [NC]
RewriteRule ^mentionslegales\.html$ / [R=301,L]

# Redirige /cgl.html vers / (301 permanent) - fichier supprimé
RewriteCond %{THE_REQUEST} /cgl\.html [NC]
RewriteRule ^cgl\.html$ / [R=301,L]

# ──────────────────────────────────────────────────────────────
# SECURITÉ & PERFORMANCE
# ──────────────────────────────────────────────────────────────

# Protéger le fichier .htaccess lui-même
<Files .htaccess>
    Order Allow,Deny
    Deny from all
</Files>

# Protéger les fichiers sensibles
<FilesMatch "\.(env|gitignore|gitattributes)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Compression GZIP pour améliorer les performances
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# Mise en cache des ressources statiques
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # CSS, JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Polices
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # Autres
    ExpiresByType text/html "access plus 1 day"
</IfModule>

# ──────────────────────────────────────────────────────────────
# EN-TÊTES DE SÉCURITÉ
# ──────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Protéger contre le clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Protéger contre le sniffing MIME
    Header always set X-Content-Type-Options "nosniff"
    
    # Protéger contre les attaques XSS
    Header always set X-XSS-Protection "1; mode=block"
    
    # Référent Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy (anciennement Feature Policy)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ──────────────────────────────────────────────────────────────
# GESTION DES ERREURS
# ──────────────────────────────────────────────────────────────
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html

# ──────────────────────────────────────────────────────────────
# OPTIONS SUPPLEMENTAIRES (optionnel)
# ──────────────────────────────────────────────────────────────

# Forcer HTTPS (décommenter si vous utilisez SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Supprimer le trailing slash (optionnel)
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^(.*)/$ /$1 [R=301,L]

# ──────────────────────────────────────────────────────────────
# NOTES
# ──────────────────────────────────────────────────────────────
# Ce fichier .htaccess :
# 1. Redirige /index.html vers / (racine)
# 2. Améliore la sécurité avec des en-têtes HTTP
# 3. Optimise les performances avec compression et cache
# 4. Protège les fichiers sensibles
#
# Testé avec Apache 2.4+
# Compatible Infomaniak