# AINTERCOM Environment Configuration
# Copy to .env and fill with your values
# Never commit .env to git!

# ════════════════════════════════════════
# Supabase Configuration
# ════════════════════════════════════════

# Your Supabase project URL
# Get from: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon public key (NOT the service role key!)
# Get from: https://app.supabase.com → Settings → API → anon key
VITE_SUPABASE_KEY=your-anon-public-key-here

# ════════════════════════════════════════
# Google OAuth Configuration
# ════════════════════════════════════════

# Google OAuth Client ID
# Get from: https://console.cloud.google.com → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret (keep private!)
# Only needed for backend - NOT used in frontend
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ════════════════════════════════════════
# Application Configuration
# ════════════════════════════════════════

# Application environment (development, staging, production)
VITE_ENV=development

# Application name
VITE_APP_NAME=AINTERCOM OS

# Application version
VITE_APP_VERSION=2.0.0

# Enable debug mode
VITE_DEBUG=false

# ════════════════════════════════════════
# Analytics (Optional)
# ════════════════════════════════════════

# Google Analytics tracking ID (optional)
VITE_GA_ID=

# Supabase analytics (auto-enabled if using auth)
VITE_SUPABASE_ANALYTICS=true

# ════════════════════════════════════════
# API Endpoints
# ════════════════════════════════════════

# Backend API URL (if you have one)
VITE_API_URL=https://api.aintercom.dev

# Public API key (if needed)
VITE_PUBLIC_API_KEY=

# ════════════════════════════════════════
# Feature Flags
# ════════════════════════════════════════

# Enable experimental features
VITE_EXPERIMENTAL_FEATURES=false

# Enable offline mode
VITE_OFFLINE_MODE=true

# Enable demo mode (useful for testing)
VITE_DEMO_MODE=false

# ════════════════════════════════════════
# OAuth Configuration (Production URLs)
# ════════════════════════════════════════

# Redirect URLs for OAuth callbacks
# Development
VITE_OAUTH_REDIRECT_DEV=http://localhost:8000

# Production
VITE_OAUTH_REDIRECT_PROD=https://morganspirli.github.io/aintercom

# Test/Staging
VITE_OAUTH_REDIRECT_STAGING=https://staging.aintercom.dev

# ════════════════════════════════════════
# Session Configuration
# ════════════════════════════════════════

# Session timeout (in hours)
VITE_SESSION_TIMEOUT=24

# Remember me duration (in days)
VITE_REMEMBER_ME_DURATION=30

# ════════════════════════════════════════
# Security
# ════════════════════════════════════════

# CORS allowed origins (comma-separated)
VITE_CORS_ORIGINS=http://localhost:8000,https://aintercom.dev

# Rate limiting (requests per minute)
VITE_RATE_LIMIT=100

# ════════════════════════════════════════
# Notes
# ════════════════════════════════════════
#
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Keep .env private (it's in .gitignore)
# 4. Never commit .env to git
# 5. For production, use environment secrets in CI/CD
#
# Values starting with VITE_ are available in browser JS
# Other values are backend-only
#
# Documentation: https://github.com/morganspirli/aintercom/wiki
